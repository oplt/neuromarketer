APP_NAME=NeuroMarketer API
APP_ENV=development
APP_VERSION=0.3.0
API_V1_PREFIX=/api/v1
ENVIRONMENT=development
DEBUG=false
LOG_LEVEL=INFO
SERVICE_NAME=neuromarketer-api
LOG_FORMAT=auto
OTEL_ENABLED=false
OTEL_SERVICE_NAME=
OTEL_EXPORTER_OTLP_ENDPOINT=

LOG_TO_FILE=false
LOG_FILE_PATH=./logs/app.log
LOG_FILE_MAX_BYTES=10485760
LOG_FILE_BACKUP_COUNT=5

# --- Database ---
# Replace with your actual connection string
DATABASE_URL=postgresql+asyncpg://neuromarketer:CHANGE_ME@localhost:5432/neuromarketer
DATABASE_ECHO=false
DATABASE_AUTO_CREATE=false

# --- Auth / Session ---
# Generate with: openssl rand -hex 64
# REQUIRED in production: must not be the default value
SESSION_SECRET=CHANGE_ME_USE_openssl_rand_hex_64
JWT_ALGORITHM=HS256
SESSION_TTL_MINUTES=10080

# --- Celery / Redis ---
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1
CELERY_INFERENCE_QUEUE=analysis-inference
CELERY_SCORING_QUEUE=analysis-scoring
CELERY_WORKER_ROLE=default
CELERY_SOFT_TIME_LIMIT_SECONDS=1800
CELERY_TIME_LIMIT_SECONDS=2100
CELERY_JOB_STALE_AFTER_SECONDS=3600
ANALYSIS_PROGRESS_SNAPSHOT_REFRESH_SECONDS=5

# --- Object Storage (MinIO / S3 / Cloudflare R2) ---
# For local dev with docker-compose MinIO:
AWS_REGION=eu-west-1
S3_BUCKET_NAME=neuromarketing-dev
S3_ENDPOINT_URL=http://minio:9000
S3_PUBLIC_BASE_URL=http://localhost:9000/neuromarketing-dev
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
AWS_SESSION_TOKEN=
LOCAL_STORAGE_ROOT=./data

# For Cloudflare R2 (optional — leave blank to use S3/MinIO above):
# Use R2 S3 Access Key ID (32 chars) and Secret — NOT a Cloudflare API token
CLOUDFLARE_R2_ACCOUNT_ID=
CLOUDFLARE_R2_ACCESS_KEY_ID=
CLOUDFLARE_R2_SECRET_ACCESS_KEY=
CLOUDFLARE_R2_BUCKET=
CLOUDFLARE_R2_PUBLIC_BASE_URL=
CLOUDFLARE_R2_ENDPOINT_URL=

# --- Upload limits ---
UPLOAD_MAX_SIZE_BYTES=262144000
ALLOWED_UPLOAD_MIME_PREFIXES='["image/", "video/", "audio/", "text/", "application/json"]'
UPLOAD_PRESIGN_EXPIRES_SECONDS=900
ANALYSIS_ALLOWED_VIDEO_MIME_TYPES=["video/mp4","video/quicktime","video/webm"]
ANALYSIS_ALLOWED_AUDIO_MIME_TYPES=["audio/mpeg","audio/mp4","audio/wav","audio/x-wav","audio/webm"]
ANALYSIS_ALLOWED_TEXT_MIME_TYPES=["text/plain","text/markdown","text/csv","text/tab-separated-values","application/json","text/html","application/xml","text/xml","application/pdf","application/msword","application/vnd.openxmlformats-officedocument.wordprocessingml.document","application/vnd.oasis.opendocument.text","application/rtf","text/rtf"]
ANALYSIS_MAX_TEXT_CHARACTERS=50000

# --- TRIBE model ---
TRIBE_MODEL_REPO_ID=facebook/tribev2
TRIBE_CHECKPOINT_NAME=best.ckpt
TRIBE_CACHE_FOLDER=./cache/tribev2
ASSET_CACHE_FOLDER=./cache/assets
TRIBE_RUNTIME_OUTPUT_CACHE_FOLDER=./cache/tribev2/runtime-output
TRIBE_DEVICE=auto
TRIBE_TEXT_FEATURE_MODEL_NAME=/app/models/phi3-mini-4k-instruct
TRIBE_FEATURE_CLUSTER=
TRIBE_HF_TOKEN=
TRIBE_VIDEO_FEATURE_FREQUENCY_HZ=0.5
TRIBE_VIDEO_MAX_IMSIZE=480
TRIBE_PRELOAD_ON_WORKER_STARTUP=true
TRIBE_VALIDATE_BINARIES_ON_WORKER_STARTUP=true
TRIBE_RUNTIME_OUTPUT_CACHE_ENABLED=true
TRIBE_RUNTIME_OUTPUT_CACHE_MAX_BYTES=5368709120
TRIBE_RUNTIME_OUTPUT_CACHE_MAX_AGE_HOURS=168
TRIBE_RUNTIME_OUTPUT_CACHE_CLEANUP_INTERVAL_MINUTES=15
TRIBE_ENABLE_ROI_SUMMARY=false

# --- LLM evaluation (optional) ---
LLM_PROVIDER=ollama
LLM_BASE_URL=http://localhost:11434
LLM_MODEL=llama3.1:8b
LLM_API_KEY=
LLM_TIMEOUT_SECONDS=300
LLM_MAX_TOKENS=300
LLM_ANALYSIS_SCORING_MAX_TOKENS=300
LLM_OLLAMA_THINK=false
LLM_TEMPERATURE=0
LLM_TOP_P=0.9
LLM_PROCESSING_STALE_AFTER_SECONDS=900
